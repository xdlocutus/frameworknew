server { listen 80; server_name example.com; root /var/www/novacore; index index.php;
location / { try_files $uri $uri/ /index.php?$query_string; }
location ~ \.php$ { include snippets/fastcgi-php.conf; fastcgi_pass unix:/run/php/php8.3-fpm.sock; }
location ~ ^/(app|core|config|database|storage|tests|bootstrap)/ { deny all; }}
