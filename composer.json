{
  "name": "novacore/framework",
  "description": "NovaCore universal modular PHP framework",
  "type": "project",
  "require": {
    "php": "^8.3",
    "vlucas/phpdotenv": "^5.6",
    "symfony/console": "^7.1",
    "firebase/php-jwt": "^6.10"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Core\\": "core/",
      "Modules\\": "modules/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "@php novacore cache:build"
    ]
  }
}
